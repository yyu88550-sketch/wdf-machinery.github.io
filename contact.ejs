<%- include('partials/header') %>

<div class="page-header">
    <h1><i class="fas fa-address-book"></i> Contact Information</h1>
    <p>Manage how customers can reach you</p>
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Type</th>
                <th>Label</th>
                <th>Value</th>
                <th>Icon</th>
                <th>Order</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% contacts.forEach(c => { %>
            <tr>
                <form action="/admin/contact/<%= c.id %>" method="POST">
                <td><%= c.type %></td>
                <td><input type="text" name="label" value="<%= c.label %>" style="width: 140px; padding: 6px;"></td>
                <td><textarea name="value" rows="2" style="width: 200px; padding: 6px;"><%= c.value %></textarea></td>
                <td><input type="text" name="icon" value="<%= c.icon %>" style="width: 120px; padding: 6px;"></td>
                <td><input type="number" name="sort_order" value="<%= c.sort_order %>" style="width: 60px; padding: 6px;"></td>
                <td>
                    <label class="checkbox-group">
                        <input type="checkbox" name="is_active" <%= c.is_active ? 'checked' : '' %>>
                    </label>
                </td>
                <td>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-save"></i> Save
                    </button>
                </td>
                </form>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>