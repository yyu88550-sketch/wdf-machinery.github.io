<%- include('partials/header') %>

<div class="page-header">
    <h1><i class="fas fa-building"></i> About Us</h1>
    <p>Edit your company information sections</p>
</div>

<% about.forEach(section => { %>
<div class="form-card" style="margin-bottom: 24px;">
    <form action="/admin/about/<%= section.id %>?type=about" method="POST" enctype="multipart/form-data">
        <h3 style="margin-bottom: 20px; color: var(--primary);"><%= section.section %></h3>
        
        <div class="form-group">
            <label>Title</label>
            <input type="text" name="title" value="<%= section.title %>">
        </div>

        <div class="form-group">
            <label>Content</label>
            <textarea name="content" rows="6"><%= section.content %></textarea>
        </div>

        <div class="form-group">
            <label>Section Image</label>
            <input type="file" name="image" accept="image/*">
            <% if (section.image) { %>
            <div class="image-preview">
                <img src="<%= section.image %>" alt="">
            </div>
            <% } %>
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Changes
        </button>
    </form>
</div>
<% }) %>

<%- include('partials/footer') %>