<%- include('partials/header') %>

<div class="page-header">
    <h1><i class="fas fa-<%= product ? 'edit' : 'plus' %>"></i> 
        <%= product ? 'Edit' : 'Add' %> Product</h1>
</div>

<div class="form-card">
    <form action="<%= product ? '/admin/products/' + product.id : '/admin/products' %>" 
          method="POST" enctype="multipart/form-data">
        
        <div class="form-row">
            <div class="form-group">
                <label>Product Name *</label>
                <input type="text" name="name" value="<%= product ? product.name : '' %>" required>
            </div>
            <div class="form-group">
                <label>Category *</label>
                <select name="category" required>
                    <option value="">Select Category</option>
                    <option value="Machinery Equipment" <%= product && product.category === 'Machinery Equipment' ? 'selected' : '' %>>Machinery Equipment</option>
                    <option value="Industrial Parts" <%= product && product.category === 'Industrial Parts' ? 'selected' : '' %>>Industrial Parts</option>
                    <option value="Hardware Accessories" <%= product && product.category === 'Hardware Accessories' ? 'selected' : '' %>>Hardware Accessories</option>
                    <option value="Automation" <%= product && product.category === 'Automation' ? 'selected' : '' %>>Automation</option>
                    <option value="Hydraulics" <%= product && product.category === 'Hydraulics' ? 'selected' : '' %>>Hydraulics</option>
                    <option value="Tools" <%= product && product.category === 'Tools' ? 'selected' : '' %>>Tools</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea name="description" rows="4"><%= product ? product.description : '' %></textarea>
        </div>

        <div class="form-group">
            <label>Specifications (one per line)</label>
            <textarea name="specs" rows="4" placeholder="Material: Stainless Steel&#10;Tolerance: ±0.01mm"><%= product ? product.specs : '' %></textarea>
            <p class="form-hint">Use format: Key: Value</p>
        </div>

        <div class="form-group">
            <label>Product Image</label>
            <input type="file" name="image" accept="image/*" <%= product ? '' : 'required' %>>
            <p class="form-hint">Recommended: 800x600px, JPG/PNG, max 5MB</p>
            <% if (product && product.image) { %>
            <div class="image-preview">
                <img src="<%= product.image %>" alt="Current image">
            </div>
            <% } %>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Sort Order</label>
                <input type="number" name="sort_order" value="<%= product ? product.sort_order : '0' %>" min="0">
            </div>
            <div class="form-group">
                <label class="checkbox-group" style="margin-top: 28px;">
                    <input type="checkbox" name="is_active" <%= product && product.is_active ? 'checked' : 'checked' %>>
                    <span>Active (visible on website)</span>
                </label>
            </div>
        </div>

        <div style="display: flex; gap: 12px;">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> <%= product ? 'Update' : 'Create' %> Product
            </button>
            <a href="/admin/products" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<%- include('partials/footer') %>