<%- include('partials/header') %>

<div class="page-header">
    <h1><i class="fas fa-<%= slide ? 'edit' : 'plus' %>"></i> 
        <%= slide ? 'Edit' : 'Add' %> Slide</h1>
</div>

<div class="form-card">
    <form action="<%= slide ? '/admin/slides/' + slide.id : '/admin/slides' %>" 
          method="POST" enctype="multipart/form-data">
        
        <div class="form-group">
            <label>Slide Title</label>
            <input type="text" name="title" value="<%= slide ? slide.title : '' %>">
        </div>

        <div class="form-group">
            <label>Subtitle</label>
            <textarea name="subtitle" rows="3"><%= slide ? slide.subtitle : '' %></textarea>
        </div>

        <div class="form-group">
            <label>Background Image</label>
            <input type="file" name="image" accept="image/*">
            <p class="form-hint">Recommended: 1920x700px for best results</p>
            <% if (slide && slide.image) { %>
            <div class="image-preview" style="width: 300px; height: 120px;">
                <img src="<%= slide.image %>">
            </div>
            <% } %>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Button Text</label>
                <input type="text" name="button_text" value="<%= slide ? slide.button_text : 'Learn More' %>">
            </div>
            <div class="form-group">
                <label>Button Link</label>
                <input type="text" name="button_link" value="<%= slide ? slide.button_link : '#products' %>">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Sort Order</label>
                <input type="number" name="sort_order" value="<%= slide ? slide.sort_order : '0' %>">
            </div>
            <div class="form-group">
                <label class="checkbox-group" style="margin-top: 28px;">
                    <input type="checkbox" name="is_active" <%= slide && slide.is_active ? 'checked' : 'checked' %>>
                    <span>Active</span>
                </label>
            </div>
        </div>

        <div style="display: flex; gap: 12px;">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> <%= slide ? 'Update' : 'Create' %> Slide
            </button>
            <a href="/admin/slides" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<%- include('partials/footer') %>