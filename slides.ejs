<%- include('partials/header') %>

<div class="page-header">
    <h1><i class="fas fa-images"></i> Hero Slides</h1>
    <p>Manage homepage hero section slides</p>
</div>

<div class="table-container">
    <div class="table-header">
        <h3>All Slides</h3>
        <a href="/admin/slides/add" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Slide
        </a>
    </div>
    <table>
        <thead>
            <tr>
                <th>Preview</th>
                <th>Title</th>
                <th>Subtitle</th>
                <th>Status</th>
                <th>Order</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% slides.forEach(s => { %>
            <tr>
                <td>
                    <% if (s.image) { %>
                    <img src="<%= s.image %>" class="table-img" style="width: 120px; height: 70px;">
                    <% } else { %>
                    <div class="table-img" style="display:flex;align-items:center;justify-content:center;font-size:12px;">No Image</div>
                    <% } %>
                </td>
                <td><%= s.title %></td>
                <td><%= s.subtitle ? s.subtitle.substring(0, 60) + '...' : '' %></td>
                <td>
                    <span class="status-badge <%= s.is_active ? 'status-active' : 'status-inactive' %>">
                        <%= s.is_active ? 'Active' : 'Inactive' %>
                    </span>
                </td>
                <td><%= s.sort_order %></td>
                <td>
                    <div class="actions">
                        <a href="/admin/slides/edit/<%= s.id %>" class="btn-edit"><i class="fas fa-edit"></i></a>
                        <form action="/admin/slides/<%= s.id %>?_method=DELETE" method="POST" style="display:inline;" 
                              onsubmit="return confirm('Delete this slide?')">
                            <button type="submit" class="btn-delete"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>