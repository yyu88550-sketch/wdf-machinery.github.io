<%- include('partials/header') %>

<div class="page-header">
    <h1><i class="fas fa-tachometer-alt"></i> Dashboard</h1>
    <p>Welcome back, <%= user.username %>. Here's your site overview.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background: rgba(26,54,93,0.1); color: #1a365d;">
            <i class="fas fa-box"></i>
        </div>
        <div class="stat-info">
            <h3><%= stats.products %></h3>
            <p>Total Products</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: rgba(22,163,74,0.1); color: #16a34a;">
            <i class="fas fa-check-circle"></i>
        </div>
        <div class="stat-info">
            <h3><%= stats.activeProducts %></h3>
            <p>Active Products</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: rgba(214,158,46,0.1); color: #d69e2e;">
            <i class="fas fa-images"></i>
        </div>
        <div class="stat-info">
            <h3><%= stats.slides %></h3>
            <p>Hero Slides</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: rgba(197,48,48,0.1); color: #c53030;">
            <i class="fas fa-address-card"></i>
        </div>
        <div class="stat-info">
            <h3><%= stats.contacts %></h3>
            <p>Contact Items</p>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="dashboard-card">
        <div class="card-header">
            <h3><i class="fas fa-bolt"></i> Quick Actions</h3>
        </div>
        <div class="quick-actions">
            <a href="/admin/products/add" class="quick-action">
                <i class="fas fa-plus-circle"></i>
                <span>Add Product</span>
            </a>
            <a href="/admin/slides/add" class="quick-action">
                <i class="fas fa-image"></i>
                <span>Add Slide</span>
            </a>
            <a href="/admin/settings" class="quick-action">
                <i class="fas fa-cog"></i>
                <span>Edit Settings</span>
            </a>
            <a href="/admin/about" class="quick-action">
                <i class="fas fa-edit"></i>
                <span>Edit About</span>
            </a>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-header">
            <h3><i class="fas fa-info-circle"></i> System Info</h3>
        </div>
        <div class="system-info">
            <div class="info-row">
                <span>Node.js Version</span>
                <span class="badge"><%= process.version %></span>
            </div>
            <div class="info-row">
                <span>Platform</span>
                <span class="badge"><%= process.platform %></span>
            </div>
            <div class="info-row">
                <span>Database</span>
                <span class="badge">SQLite3</span>
            </div>
            <div class="info-row">
                <span>Template Engine</span>
                <span class="badge">EJS</span>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>